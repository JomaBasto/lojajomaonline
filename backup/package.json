import { useEffect, useState } from "react";
import {
  collection,
  getDocs,
  deleteDoc,
  doc,
  updateDoc,
  addDoc
} from "firebase/firestore";
import { db } from "./firebase";
import "./App.css";

export default function App() {
  const [category, setCategory] = useState("all");
  const [products, setProducts] = useState([]);

  // ➕ ADICIONAR PRODUTO
  const addProduct = async () => {
    const name = prompt("Nome do produto:");
    const price = prompt("Preço:");
    const imageUrl = prompt("Imagem URL:");

    if (!name || !price || !imageUrl) return;

    await addDoc(collection(db, "products"), {
      name,
      price,
      imageUrl,
      images: []
    });

    window.location.reload();
  };

  // 📦 CARREGAR PRODUTOS
  useEffect(() => {
    const filteredProducts =
  category === "all"
    ? products
    : products.filter((p) => p.category === category);
    async function loadProducts() {
      const snapshot = await getDocs(collection(db, "products"));

      const data = snapshot.docs.map((doc) => ({
        id: doc.id,
        ...doc.data(),
      }));

      setProducts(data);
    }

    loadProducts();
  }, []);

  return (
    <div>

      {/* HEADER */}
      <header className="header">

        <h1 className="logo">
          JomaBasto Store
        </h1>

        <nav className="nav">

          {/* HOMEM */}
          <div className="dropdown">
            <a>Homem ▾</a>

            <div className="dropdown-menu">
              <a>Running</a>
              <a>Trail</a>
              <a>Futebol</a>
              <a>Futsal</a>
              <a>Andebol</a>
              <a>Voleibol</a>
              <a>Basquetebol</a>
              <a>Ténis</a>
              <a>Padel</a>
              <a>Casual</a>
              <a>Verão</a>
            </div>
          </div>

          {/* MULHER */}
          <div className="dropdown">
            <a>Mulher ▾</a>

            <div className="dropdown-menu">
              <a>Running</a>
              <a>Trail</a>
              <a>Futebol</a>
              <a>Futsal</a>
              <a>Andebol</a>
              <a>Voleibol</a>
              <a>Basquetebol</a>
              <a>Ténis</a>
              <a>Padel</a>
              <a>Casual</a>
              <a>Verão</a>
            </div>
          </div>

          {/* CRIANÇA */}
          <div className="dropdown">
            <a>Criança ▾</a>

            <div className="dropdown-menu">
              <a>Running</a>
              <a>Trail</a>
              <a>Futebol</a>
              <a>Futsal</a>
              <a>Casual</a>
              <a>Verão</a>
            </div>
          </div>

          {/* ACESSÓRIOS */}
          <div className="dropdown">
            <a>Acessórios ▾</a>

            <div className="dropdown-menu">
              <a>Bola Futebol</a>
              <a>Bola Futsal</a>
              <a>Mochilas</a>
              <a>Meias</a>
              <a>Luvas</a>
              <a>Acessórios de Trail/Running</a>
              <a>Piscina</a>
              <a>Bonés</a>
              <a>Outros</a>
            </div>
          </div>

          <a>Outlet</a>

        </nav>

      </header>

      {/* HERO */}
      <section className="hero">
        <div className="overlay">
          <h2>NUNCA PARES</h2>
          <p>Descobre a nova coleção desportiva premium.</p>
          <button>Comprar Agora</button>
        </div>
      </section>

      {/* PRODUTOS */}
      <section className="products-section">

        <h2>🔥 Novidades</h2>

        {/* ➕ BOTÃO ADICIONAR */}
        <button onClick={addProduct}>
          + Adicionar Produto
        </button>

        <div className="grid">

          {products.map((p) => (
            <div className="card" key={p.id}>

              <img
                src={p.imageUrl || "https://via.placeholder.com/300"}
                alt={p.name}
              />

              <div className="info">

                <h3>{p.name}</h3>

                <p className="price">
                  {p.price} €
                </p>

                <button>
                  Adicionar ao Carrinho
                </button>

              </div>

            </div>
          ))}

        </div>

      </section>

      {/* FOOTER */}
      <footer className="footer">
        <p>© 2026 JOMA STORE — Todos os direitos reservados</p>
      </footer>

    </div>
  );
}


App.css

:root {
  --primary: #0057b8;
  --primary-dark: #004494;
  --text: #111;
  --background: #f5f5f5;
  --white: #ffffff;
}* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* BODY */

body {
  font-family: Arial, sans-serif;
  background: #f5f5f5;
  color: #111;
}

/* HEADER */

.header {
  position: fixed;
  top: 0;
  width: 100%;

  background: #0057b8;

  color: white;

  padding: 20px 60px;

  display: flex;
  justify-content: space-between;
  align-items: center;

  z-index: 1000;

  box-shadow: 0 4px 15px rgba(0,0,0,0.2);
}

/* LOGO */

.logo {
  font-size: 30px;
  font-weight: bold;
  color: white;
  letter-spacing: 1px;
}

/* NAV */

.header nav {
  display: flex;
  gap: 30px;
}

.header nav a {
  color: white !important;
  text-decoration: none;
  font-weight: bold;
  cursor: pointer;
  transition: 0.3s;
  opacity: 1;
}

.header nav a:hover {
  color: #e6e6e6;
  opacity: 1;
}

/* 🔥 BOTÕES PRETOS */

button {
  background-color: black;
  color: white;

  border: 1px solid black;

  padding: 8px 14px;

  cursor: pointer;

  transition: 0.2s;
}

button:hover {
  background-color: white;
  color: black;
}

/* HERO */

.hero {
  height: 100vh;

  background-image: url("https://images.joma-sport.com/ka/apps/joma/files/20250513_134223_rmetls2612_3_.jpg");

  background-size: cover;
  background-position: center;
}

.overlay {
  width: 100%;
  height: 100%;

  background: rgba(0,0,0,0.5);

  display: flex;
  flex-direction: column;
  justify-content: center;

  padding-left: 80px;
}

.overlay h2 {
  color: white;
  font-size: 80px;
}

.overlay p {
  color: white;
  font-size: 24px;
  margin: 20px 0;
}

.overlay button {
  width: 220px;

  padding: 15px;

  border: none;

  background: white;

  font-size: 18px;
  font-weight: bold;

  cursor: pointer;

  transition: 0.3s;
}

.overlay button:hover {
  background: #0057b8;
  color: white;
}

/* PRODUCTS */

.products-section {
  padding: 80px 60px;
}

.products-section h2 {
  font-size: 40px;
  margin-bottom: 40px;
}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 30px;
}

.card {
  background: white;
  border-radius: 15px;
  overflow: hidden;
  transition: 0.3s;
  box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}

.card:hover {
  transform: translateY(-8px);
}

.card img {
  width: 100%;
  height: 300px;
  object-fit: cover;
}

.info {
  padding: 20px;
}

.info h3 {
  margin-bottom: 10px;
}

.price {
  font-size: 24px;
  font-weight: bold;
  margin-bottom: 15px;
}

.info button {
  width: 100%;
  padding: 14px;

  border: none;

  background: #0057b8;
  color: white;

  font-weight: bold;

  cursor: pointer;

  transition: 0.3s;
}

.info button:hover {
  opacity: 0.9;
}

/* FOOTER */

.footer {
  background: #0057b8;
  color: white;

  text-align: center;

  padding: 30px;

  margin-top: 60px;
}

/* NAV + DROPDOWN */

.nav {
  display: flex;
  gap: 20px;
  align-items: center;
}

.dropdown {
  position: relative;
  cursor: pointer;
}

.dropdown-menu {
  position: absolute;
  top: 20px;
  left: 0;

  background: white;
  border: 1px solid #ddd;

  display: flex;
  flex-direction: column;

  min-width: 150px;

  z-index: 1000;
}

.dropdown-menu a {
  padding: 8px;
  color: black;
  text-decoration: none;
  cursor: pointer;
}

.dropdown-menu a:hover {
  background: #eee;
  color: black;
}

.dropdown-menu a:hover {
  background: #eee;
}.logo-img {
  height: 40px;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 8px;

  background: white;
  padding: 6px 12px;
  border-radius: 20px;
}

.search-box input {
  border: none;
  outline: none;
}

.icons {
  color: white;
  cursor: pointer;
}.card img {
  width: 100%;
  height: 300px;
  object-fit: cover;
  border-bottom: 1px solid #eee;
}.dropdown {
  position: relative;
  cursor: pointer;
}

.dropdown-menu {
  position: absolute;
  top: 25px;
  left: 0;

  background: white;
  border: 1px solid #ddd;

  display: none;
  flex-direction: column;

  min-width: 180px;
  z-index: 1000;
}

.dropdown-menu a {
  padding: 10px;
  color: black;
  text-decoration: none;
}

.dropdown-menu a:hover {
  background: #8a1414;
}

/* 🔥 abre menu ao passar rato */
.dropdown:hover .dropdown-menu {
  display: flex;
}.dropdown-menu a {
  color: black;
  font-weight: 500;
}

.dropdown-menu a:hover {
  color: #0057b8;
}.header nav a {
  background: var(--primary);
  color: white;
  padding: 6px 12px;
  border-radius: 6px;
}


