    imageUrl: "",
    category: "homem-running",
    description: "",
    sizes: []
  });

  setShowForm(false);
};

  // 📦 CARREGAR PRODUTOS
  useEffect(() => {
    async function loadProducts() {
      const snapshot = await getDocs(collection(db, "products"));

      const data = snapshot.docs.map((doc) => ({
        id: doc.id,
        ...doc.data(),
      }));

      setProducts(data);
    }

    loadProducts();
  }, []);

